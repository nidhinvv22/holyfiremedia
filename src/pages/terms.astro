---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Terms & Conditions">
  <div class="min-h-screen bg-gradient-to-br from-purple-900 via-indigo-900 to-blue-900 text-white">
    <main class="container mx-auto px-4 py-20 max-w-3xl">
      <h1 class="text-4xl md:text-5xl font-extrabold mb-6">Terms & Conditions</h1>
      <div class="bg-white/10 backdrop-blur-lg border border-white/20 rounded-2xl p-8 space-y-5 text-purple-100">
        <section class="space-y-2">
          <h2 class="text-2xl font-semibold text-white">Digital Product Sale</h2>
          <p>All items sold on this site are digital karaoke tracks.</p>
        </section>
        <section class="space-y-2">
          <h2 class="text-2xl font-semibold text-white">Personal Use Only</h2>
          <p>Usage is limited to personal use and enjoyment.</p>
        </section>
        <section class="space-y-2">
          <h2 class="text-2xl font-semibold text-white">No Redistribution</h2>
          <p>Redistribution, resale, or sharing of purchased content is prohibited.</p>
        </section>
        <section class="space-y-2">
          <h2 class="text-2xl font-semibold text-white">Access After Payment</h2>
          <p>Download access is provided once payment is complete.</p>
        </section>
      <section class="space-y-2">
          <h2 class="text-2xl font-semibold text-white">    Business & Tax Information</h2>
          <p>This business is registered under GST laws of India. GST details will be shared on invoice after purchase.</p>
        </section>
      </div>
    </main>

    <footer class="border-t border-white/10 py-6">
      <div class="container mx-auto px-4 text-center text-purple-200">
        <p>© 2026 HolyfireMedia | Contact: jmmusicdistribution@gmail.com</p>
      </div>
    </footer>
  </div>
</Layout>
