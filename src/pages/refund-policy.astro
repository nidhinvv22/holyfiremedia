---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Refund Policy">
  <div class="min-h-screen bg-gradient-to-br from-purple-900 via-indigo-900 to-blue-900 text-white">
    <main class="container mx-auto px-4 py-20 max-w-3xl">
      <h1 class="text-4xl md:text-5xl font-extrabold mb-6">Refund Policy</h1>
      <div class="bg-white/10 backdrop-blur-lg border border-white/20 rounded-2xl p-8 space-y-4 text-purple-100">
        <p>All sales are final. Since this is a digital product, no refunds will be issued once the download link is delivered.</p>
      </div>
    </main>

    <footer class="border-t border-white/10 py-6">
      <div class="container mx-auto px-4 text-center text-purple-200">
        <p>© 2026 HolyfireMedia | Contact: jmmusicdistribution@gmail.com</p>
      </div>
    </footer>
  </div>
</Layout>
