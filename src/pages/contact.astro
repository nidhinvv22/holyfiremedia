---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Contact Us | HolyfireMedia" description="Get in touch with HolyfireMedia for queries.">
  <div class="container mx-auto px-4 py-20 max-w-4xl min-h-[60vh] flex items-center justify-center">
    <div class="w-full bg-indigo-900/30 backdrop-blur-xl border border-white/10 rounded-3xl p-8 md:p-16 shadow-2xl relative overflow-hidden">
      
      <div class="absolute -bottom-24 -right-24 w-64 h-64 bg-pink-500/20 rounded-full blur-3xl mix-blend-screen pointer-events-none"></div>

      <div class="relative z-10 text-center">
        <h1 class="text-3xl sm:text-4xl md:text-6xl font-extrabold text-white mb-6">Get in Touch</h1>
        <p class="text-lg sm:text-xl text-purple-200 mb-12 max-w-2xl mx-auto px-2">
          We'd love to hear from you. For any queries, suggestions, or support, please reach out to us via email.
        </p>

        <div class="bg-white/10 backdrop-blur-lg border border-white/20 rounded-2xl p-6 sm:p-8 md:p-12 inline-flex flex-col items-center justify-center hover:shadow-[0_0_30px_rgba(236,72,153,0.3)] transition-shadow w-full max-w-lg mx-auto">
          <div class="h-16 w-16 sm:h-20 sm:w-20 rounded-full bg-gradient-to-br from-pink-500 to-purple-600 flex items-center justify-center shadow-lg mb-6">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </div>
          <h2 class="text-2xl sm:text-3xl font-bold text-white mb-2">Email Us</h2>
          <a href="mailto:jmmusicdistribution@gmail.com" class="text-lg sm:text-xl md:text-2xl font-bold bg-clip-text text-transparent bg-gradient-to-r from-pink-300 to-purple-300 hover:text-white transition-colors break-all text-center">
            jmmusicdistribution@gmail.com
          </a>
          <p class="text-purple-300 mt-4">We usually respond within 24-48 hours.</p>
        </div>
      </div>

    </div>
  </div>
</MainLayout>
