---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact Us">
  <div class="min-h-screen bg-gradient-to-br from-purple-900 via-indigo-900 to-blue-900 text-white">
    <main class="container mx-auto px-4 py-20 max-w-3xl">
      <h1 class="text-4xl md:text-5xl font-extrabold mb-6">Contact Us</h1>
      <div class="bg-white/10 backdrop-blur-lg border border-white/20 rounded-2xl p-8 space-y-3">
        <p class="text-lg text-purple-100">HolyfireMedia</p>
        <p class="text-lg text-purple-100">Email: <a href="mailto:jmmusicdistribution@gmail.com" class="text-white underline">jmmusicdistribution@gmail.com</a></p>
        <p class="text-lg text-purple-100">For any queries, please contact via email.</p>
      </div>
    </main>

    <footer class="border-t border-white/10 py-6">
      <div class="container mx-auto px-4 text-center text-purple-200">
        <p>© 2026 HolyfireMedia | Contact: jmmusicdistribution@gmail.com</p>
      </div>
    </footer>
  </div>
</Layout>
