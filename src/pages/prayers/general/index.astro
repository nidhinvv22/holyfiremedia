---
import MainLayout from '../../../layouts/MainLayout.astro';

const generalPrayers = [
  { slug: "prayer-for-priests", title: "Vaidikarkkuvendiyulla Prarthana", description: "വൈദികർക്കുവേണ്ടി പ്രാർത്ഥന - Prayer for Priests", icon: "🙏" },
  { slug: "precious-blood", title: "Thiruraktha Samrakshana Prarthana", description: "തിരുരക്ത സംരക്ഷണ പ്രാർത്ഥന - Precious Blood Protection", icon: "🩸" },
  { slug: "prayer-to-mother-mary", title: "Mathavinodulla Samrakshana...", description: "മാതാവിനോടുള്ള സംരക്ഷണ പ്രാർത്ഥന - Mother Mary", icon: "🌹" },
  { slug: "guardian-angel", title: "Kaval Malakhayodulla Prarthana", description: "കാവൽ മാലാഖയോടുള്ള പ്രാർത്ഥന - Guardian Angel", icon: "👼" },
  { slug: "maundy-thursday", title: "Pesahavyazham Appammurikkal", description: "പെസഹാവ്യാഴം അപ്പംമുറിക്കൽ... - Maundy Thursday", icon: "🍞" },
  { slug: "three-oclock-prayer", title: "Moonnumani Japam", description: "മൂന്നുമണി ജപം - Three O'Clock Prayer", icon: "🕒" },
  { slug: "students-prayer", title: "Vidyarthikalude Prarthana", description: "വിദ്യാർത്ഥികളുടെ പ്രാർത്ഥന - Prayer for Students", icon: "📚" },
  { slug: "st-francis-assisi", title: "St. Francis Assisiyude Prarthana", description: "വി. ഫ്രാൻസിസ് അസ്സീസ്സിയുടെ കാരുണ്യ പ്രാർത്ഥന", icon: "🕊️" },
  { slug: "job-seekers", title: "Thozhilanveshakarude Prarthana", description: "തൊഴിലന്വേഷകരുടെ പ്രാർത്ഥന - For Job Seekers", icon: "💼" },
  { slug: "couples-prayer", title: "Dambathikalude Prarthana", description: "ദമ്പതികളുടെ പ്രാർത്ഥന - Prayer for Couples", icon: "💑" },
  { slug: "childless-prayer", title: "Makkalillathavarkkuvendiyulla...", description: "മക്കളില്ലാത്തവർക്കുവേണ്ടിയുള്ള... - For the childless", icon: "👶" },
  { slug: "parents-prayer-for-children", title: "Makkalkkuvendiyulla Mathapithakkalude...", description: "മക്കൾക്കുവേണ്ടിയുള്ള മാതാപിതാക്കളുടെ...", icon: "👨‍👩‍👧‍👦" },
  { slug: "family-prayer", title: "Kudumbathinu Vendiyulla Prarthana", description: "കുടുംബത്തിന് വേണ്ടിയുള്ള പ്രാർത്ഥന - Family Prayer", icon: "🏡" },
  { slug: "before-sleep", title: "Urangum Munpu", description: "ഉറങ്ങും മുൻപ് - Prayer Before Sleep", icon: "😴" },
  { slug: "pregnant-women", title: "Garbhinikalude Japam", description: "ഗർഭിണികളുടെ ജപം - Prayer for Pregnant Women", icon: "🤰" }
];
---

<MainLayout title="Prarthanakal | HolyfireMedia" description="A collection of General Catholic Prayers in Malayalam.">
  <div class="container mx-auto px-4 py-8 md:py-16">
    <div class="max-w-3xl mx-auto text-center mb-12">
      <h1 class="text-3xl md:text-5xl font-extrabold text-white mb-6">പ്രാർത്ഥനകൾ (General Prayers)</h1>
      <p class="text-xl text-purple-200 mt-2">
        Specific devotions and intercessions for all walks of life.
      </p>
    </div>

    <!-- Back to Prayers Breadcrumb -->
    <div class="max-w-3xl mx-auto mb-8">
      <a href="/prayers" class="text-pink-300 hover:text-pink-400 font-medium flex items-center gap-1 group w-max">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 group-hover:-translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
        Back to Devotions
      </a>
    </div>

    <div class="space-y-4 max-w-3xl mx-auto">
      {generalPrayers.map((item) => (
        <a href={`/prayers/general/${item.slug}`} class="block group">
          <div class="flex items-center gap-6 bg-gradient-to-r from-indigo-900/40 to-purple-900/40 backdrop-blur-md border border-white/10 rounded-2xl p-6 shadow-xl hover:bg-white/10 hover:border-pink-500/30 hover:scale-[1.02] transition-all duration-300">
            <div class="text-4xl bg-white/5 p-3 rounded-xl border border-white/5 flex items-center justify-center">
              {item.icon}
            </div>
            <div class="flex-1">
              <h2 class="text-xl sm:text-2xl font-bold text-white mb-1 group-hover:text-pink-300 transition-colors">{item.title}</h2>
              <p class="text-purple-200 text-sm hidden sm:block">{item.description}</p>
            </div>
            <div class="text-right flex flex-col items-end">
              <span class="text-sm font-semibold text-pink-400 bg-pink-500/10 px-3 py-1 rounded-full mb-1">
                Read
              </span>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-white/50 group-hover:text-pink-300 group-hover:translate-x-1 transition-all" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</MainLayout>
