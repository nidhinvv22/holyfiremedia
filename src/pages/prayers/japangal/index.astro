---
import MainLayout from '../../../layouts/MainLayout.astro';

const japangal = [
  { slug: "kurishadayalam-cheruth", title: "Kurishadayalam (Cheruth)", description: "കുരിശടയാളം (ചെറുത്) - Sign of the Cross (Small)", icon: "✝️" },
  { slug: "kurishadayalam-valuth", title: "Kurishadayalam (Valuth)", description: "കുരിശടയാളം (വലുത്) - Sign of the Cross (Large)", icon: "✝️" },
  { slug: "thrithva-sthuthi", title: "Thrithva Sthuthi", description: "ത്രിത്വ സ്തുതി - Glory Be", icon: "✨" },
  { slug: "swargasthanaya-pithave", title: "Swargasthanaya Pithave", description: "സ്വർഗ്ഗസ്ഥനായ ഞങ്ങളുടെ പിതാവേ - Our Father", icon: "☁️" },
  { slug: "nanma-niranja-mariyam", title: "Nanma Niranja Mariyam", description: "നന്മ നിറഞ്ഞ മറിയം - Hail Mary", icon: "🌹" },
  { slug: "vishwasapramanam", title: "Vishwasapramanam", description: "വിശ്വാസപ്രമാണം - The Apostles' Creed", icon: "📜" },
  { slug: "thrisandhyajapangal", title: "Thrisandhyajapangal", description: "ത്രിസന്ധ്യാജപങ്ങൾ - The Angelus", icon: "🌅" },
  { slug: "kumbasarathinulla-japam", title: "Kumbasarathinulla Japam", description: "കുമ്പസാരത്തിനുള്ള ജപം - Prayer for Confession", icon: "🙏" },
  { slug: "manasthapa-prakaranam", title: "Manasthapa Prakaranam", description: "മനസ്താപ പ്രകരണം - Act of Contrition", icon: "❤️" },
  { slug: "ethrayum-dayayulla-mathave", title: "Ethrayum Dayayulla Mathave", description: "എത്രയും ദയയുള്ള മാതാവേ - The Memorare", icon: "💖" },
  { slug: "parishudha-rajni", title: "Parishudha Rajni", description: "പരിശുദ്ധ രാജ്ഞി - Hail Holy Queen", icon: "👑" },
];
---

<MainLayout title="Japangal | HolyfireMedia" description="A collection of Common Prayers in Malayalam.">
  <div class="container mx-auto px-4 py-8 md:py-16">
    <div class="max-w-3xl mx-auto text-center mb-12">
      <h1 class="text-3xl md:text-5xl font-extrabold text-white mb-6">ജപങ്ങൾ (Common Prayers)</h1>
      <p class="text-xl text-purple-200 mt-2">
        Daily Catholic prayers structured in Malayalam and Manglish.
      </p>
    </div>

    <!-- Back to Prayers Breadcrumb -->
    <div class="max-w-3xl mx-auto mb-8">
      <a href="/prayers" class="text-pink-300 hover:text-pink-400 font-medium flex items-center gap-1 group w-max">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 group-hover:-translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
        Back to Devotions
      </a>
    </div>

    <div class="space-y-4 max-w-3xl mx-auto">
      {japangal.map((item) => (
        <a href={`/prayers/japangal/${item.slug}`} class="block group">
          <div class="flex items-center gap-6 bg-gradient-to-r from-indigo-900/40 to-purple-900/40 backdrop-blur-md border border-white/10 rounded-2xl p-6 shadow-xl hover:bg-white/10 hover:border-pink-500/30 hover:scale-[1.02] transition-all duration-300">
            <div class="text-4xl bg-white/5 p-3 rounded-xl border border-white/5 flex items-center justify-center">
              {item.icon}
            </div>
            <div class="flex-1">
              <h2 class="text-xl sm:text-2xl font-bold text-white mb-1 group-hover:text-pink-300 transition-colors">{item.title}</h2>
              <p class="text-purple-200 text-sm hidden sm:block">{item.description}</p>
            </div>
            <div class="text-right flex flex-col items-end">
              <span class="text-sm font-semibold text-pink-400 bg-pink-500/10 px-3 py-1 rounded-full mb-1">
                Read
              </span>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-white/50 group-hover:text-pink-300 group-hover:translate-x-1 transition-all" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</MainLayout>
