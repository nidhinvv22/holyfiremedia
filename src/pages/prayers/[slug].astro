---
import MainLayout from '../../layouts/MainLayout.astro';

export function getStaticPaths() {
  const prayers = [
    { 
      slug: "holy-rosary", 
      title: "Malayalam Holy Rosary (ജപമാല)", 
      manglishText: `
        <h2 class="text-2xl font-bold mb-4 text-center">Parishudha Kanyakamathavinte Japamala</h2>

        <h3 class="text-xl text-pink-400 font-bold mt-6 mb-2">Prarambha Prarthana</h3>
        <p class="mb-4 text-justify">Alavillatha sakala nanma swaroopanayirikkunna sarveshwara karthave, nissararum nandiketta papikalumaya njangal nisseemapratapavanaya ange sannidhiyil prarthikkuvan ayogyarakunnu. Engilum ange ananthamaya dayayil sharanappettukondu, parishudha daivamathavinte sthuthikkai japamala yarpikkuvan njangal agrahikkunnu. Ee arppanam bhakthiyodum shradhayodum koode cheyyunnathinu karthave, njangale anugrahikkaname.</p>

        <h3 class="text-xl text-pink-400 font-bold mt-6 mb-2">Sarvashakthanaya pithavum.......</h3>
        <p class="text-right text-pink-300 font-bold mb-2">1. Swarga.</p>

        <p class="mb-4 text-justify">Pithavaya daivathinte makalayirikkunna parishudha mariyame, njangalil daivavishwasamenna punyamundayi phalam cheyyunnathinu ange thirukkumaranodu apekshikkaname.</p>
        <p class="text-right text-pink-300 font-bold mb-2">1. Nanma.</p>

        <p class="mb-4 text-justify">Puthranaya daivathinte mathavayirikkunna parishudha mariyame, njangalil daivasharanam enna punyamundayi valarunnathinu ange thirukkumaranodu apekshikkaname.</p>
        <p class="text-right text-pink-300 font-bold mb-2">1. Nanma.</p>

        <p class="mb-4 text-justify">Parishudhathmavaya daivathinu ettavum priyamulla parishudha mariyame, njangalil daivasnehamenna punyamundayi vardhikkunnathinu ange thirukkumaranodu apekshikkaname.</p>
        <p class="text-right text-pink-300 font-bold mb-2">1. Nanma. 1. Thrithva.</p>

        <div class="bg-red-900/20 border border-red-500/30 p-5 rounded-xl mt-8 mb-6">
          <h3 class="text-xl font-bold text-center text-white mb-4">Konthayude oro dashakavum kazhinju chollunna Fathima sukruthajapam</h3>
          <p class="text-center italic text-purple-100">Oh! Ente eeshoye, njangalude papangal kshamikkaname, narakagniyil ninnu njangale rakshikkaname. Ella aathmakkaleyum prathyekam ange sahayavum kooduthal aavashyamullavareyum swargathilekku aanayikkaname.</p>
          <p class="text-center font-bold mt-4 text-pink-300">Parishudha japamalayude raajni, njangalkkuvendi apekshikkaname.</p>
        </div>

        <div class="bg-pink-900/20 border border-pink-500/30 p-5 rounded-xl mt-8 mb-6">
          <h3 class="text-xl font-bold text-center text-white mb-2">Santhoshakaramaya Divyarahasyangal</h3>
          <p class="text-center text-pink-300 mb-6 text-sm">(Thinkal, Shani divasangali chollunnu.)</p>
          <ol class="list-decimal list-outside pl-5 space-y-6 text-purple-100">
            <li class="pl-2">Parishudha daivamathavu garbham dharichu eeshomishihaye prasavikkumenna mangalavartha gabriyel malakha daivakalpanayal ariyichu ennu dhyanikkuka.<br><span class="text-pink-400 font-bold block text-right mt-2">1. Swarga. 10. Nanma. 1. Thrithva.</span></li>
            <li class="pl-2">Parishudha daivamathavu, eleeshwa garbhiniyaya vivaram kettappol aa punyavathiye chennukandu moonnu masatholam avalkku shushrusha cheythu ennu dhyanikkuka.<br><span class="text-pink-400 font-bold block text-right mt-2">1. Swarga. 10. Nanma. 1. Thrithva.</span></li>
            <li class="pl-2">Parishudha daivamathavu thante udarathil ulbhavicha daivakumaranne prasavippan kalamayappol bethlehem nagariyil pathiraykku prasavichu oru thozhukkootil kidathi ennu dhyanikkuka.<br><span class="text-pink-400 font-bold block text-right mt-2">1. Swarga. 10. Nanma. 1. Thrithva.</span></li>
            <li class="pl-2">Parishudha daivamathavu thante shudheekaranathinte naal vannappol eeshomishihaye devalayathil konduchennu daivathinu kazhchavachu shimayon enna mahathmavinte karangalil elppichu ennu dhyanikkuka.<br><span class="text-pink-400 font-bold block text-right mt-2">1. Swarga. 10. Nanma. 1. Thrithva.</span></li>
            <li class="pl-2">Parishudha daivamathavu thante divyakumaranu panthrandu vayassayirikke moonnu divasam avidathe kanathe anveshichittu moonnam naal devalayathil vachu vedashasthrikalumayi tharkkichirikkeyil avide kandethi ennu dhyanikkuka.<br><span class="text-pink-400 font-bold block text-right mt-2">1. Swarga. 10. Nanma. 1. Thrithva.</span></li>
          </ol>
        </div>

        <div class="bg-indigo-900/20 border border-indigo-500/30 p-5 rounded-xl mt-8 mb-6">
          <h3 class="text-xl font-bold text-center text-white mb-2">Prakashathinte Divyarahasyangal</h3>
          <p class="text-center text-indigo-300 mb-6 text-sm">(Vyazhazhchakalil chollunnu)</p>
          <ol class="list-decimal list-outside pl-5 space-y-6 text-purple-100">
            <li class="pl-2">Nammude karthaveeshomishiha jordan nadiyil vachu snapakayohannante karangalil ninnu mammodisa sweekarichappol swargam thurakkappedukayum parishudhathmavu pravinte roopathil avidathemel ezhunnalli varikayum cheythu ennu dhyanikkuka.<br><span class="text-indigo-400 font-bold block text-right mt-2">1. Swarga. 10. Nanma. 1. Thrithva.</span></li>
            <li class="pl-2">Nammude karthaveeshomishiha kanayil vachu vivahavirunninte avasarathil parishudha ammayude madhyasthathal vellam veenjakki thante adyathe albhutham pravarthichu ennu dhyanikkuka.<br><span class="text-indigo-400 font-bold block text-right mt-2">1. Swarga. 10. Nanma. 1. Thrithva.</span></li>
            <li class="pl-2">Nammude karthaveeshomishiha jordanile mammodisaykkum marubhoomiyile orukkathinum shesham daivarajyathinte aagamanathekkurichulla suvishesham prasangikkuvan arambhichu ennu dhyanikkuka.<br><span class="text-indigo-400 font-bold block text-right mt-2">1. Swarga. 10. Nanma. 1. Thrithva.</span></li>
            <li class="pl-2">Nammude karthaveeshomishiha thabor malamukalil vachu thante priyappetta shishyanmarude sannidhyathil roopantharappettu thante swargeeyamahathvam avarkku velippeduthi ennu dhyanikkuka.<br><span class="text-indigo-400 font-bold block text-right mt-2">1. Swarga. 10. Nanma. 1. Thrithva.</span></li>
            <li class="pl-2">Nammude karthaveeshomishiha sehiyon oottushalayil vachu shishyanmarude padangal kazhukukayum avarkku snehathinte puthiya kalpana nalkukayum cheytha shesham avidathe sandehathinte shashvathasmarakamaya vishudha kurbana sthapichu ennu dhyanikkuka.<br><span class="text-indigo-400 font-bold block text-right mt-2">1. Swarga. 10. Nanma. 1. Thrithva.</span></li>
          </ol>
        </div>

        <div class="bg-red-900/20 border border-red-500/30 p-5 rounded-xl mt-8 mb-6">
          <h3 class="text-xl font-bold text-center text-white mb-2">Dukhakaramaya Divya Rahasyangal</h3>
          <p class="text-center text-red-300 mb-6 text-sm">(Chovva, Velli divasangali chollunnu)</p>
          <ol class="list-decimal list-outside pl-5 space-y-6 text-purple-100">
            <li class="pl-2">Nammude karthaveeshomishiha poonkavanathil prarthichirikkumbol chora viyarthu ennu dhyanikkuka.<br><span class="text-red-400 font-bold block text-right mt-2">1. Swarga. 10. Nanma. 1. Thrithva.</span></li>
            <li class="pl-2">Nammude karthaveeshomishiha peelathosinte veettil vachu chammattikalal adikkappettu ennu dhyanikkuka.<br><span class="text-red-400 font-bold block text-right mt-2">1. Swarga. 10. Nanma. 1. Thrithva.</span></li>
            <li class="pl-2">Nammude karthaveeshomishihaye yoodanmar mulmudi dharipichu ennu dhyanikkuka.<br><span class="text-red-400 font-bold block text-right mt-2">1. Swarga. 10. Nanma. 1. Thrithva.</span></li>
            <li class="pl-2">Nammude karthaveeshomishiha maranathinu vidhikkappettathinushesham thanikku adhikam apamanavum vyakulavumundakuvan vendi avidathe thirutholinmel bharamulla kurishumaram chumathappettu ennu dhyanikkuka.<br><span class="text-red-400 font-bold block text-right mt-2">1. Swarga. 10. Nanma. 1. Thrithva.</span></li>
            <li class="pl-2">Nammude karthaveeshomishiha gagulthamalayil chennappol vyakulasamudrathil muzhukiya parishudha mathavinte mumbake thiruvasthrangalurinjadukkappettu, kurishinmel tharaykkappettu ennu dhyanikkuka.<br><span class="text-red-400 font-bold block text-right mt-2">1. Swarga. 10. Nanma. 1. Thrithva.</span></li>
          </ol>
        </div>

        <div class="bg-yellow-900/20 border border-yellow-500/30 p-5 rounded-xl mt-8 mb-6">
          <h3 class="text-xl font-bold text-center text-white mb-2">Mahimayude Divyarahasyangal</h3>
          <p class="text-center text-yellow-300 mb-6 text-sm">(Budhan, Njanyar divasangali chollunnu)</p>
          <ol class="list-decimal list-outside pl-5 space-y-6 text-purple-100">
            <li class="pl-2">Nammude karthaveeshomishiha peedasahichu marichathinte moonnam naal jayasanthoshangalode uyirthezhunnalli ennu dhyanikkuka.<br><span class="text-yellow-400 font-bold block text-right mt-2">1. Swarga. 10. Nanma. 1. Thrithva.</span></li>
            <li class="pl-2">Nammude karthaveeshomishiha thante uyirppinte shesham nalpatham naal albhuthakaramaya mahimayodum jayathodum koode thante divyamathavum shishyarum kandukondu nilkkumbol swargarohanam cheythu ennu dhyanikkuka.<br><span class="text-yellow-400 font-bold block text-right mt-2">1. Swarga. 10. Nanma. 1. Thrithva.</span></li>
            <li class="pl-2">Nammude karthaveeshomishiha pithavaya daivathinte valathubhagathu ezhunnalliyirikkumbol sehiyon oottushalayil dhyanichirunna kanyakamathavinte melum shleehanmarude melum parishudhathmavine ayachu ennu dhyanikkuka.<br><span class="text-yellow-400 font-bold block text-right mt-2">1. Swarga. 10. Nanma. 1. Thrithva.</span></li>
            <li class="pl-2">Nammude karthaveeshomishiha uyirthezhunnelli kurakkalam kazhinjappol kanyakamathavu ee lokathilninnu malakhamaral swargathilekku adukkappettu ennu dhyanikkuka.<br><span class="text-yellow-400 font-bold block text-right mt-2">1. Swarga. 10. Nanma. 1. Thrithva.</span></li>
            <li class="pl-2">Parishudha daivamathavu, paralokathethiya udane thante divyakumaranal swargathinteyum bhoomiyudeyum raajniyayi mudi dharikkappettu ennu dhyanikkuka.<br><span class="text-yellow-400 font-bold block text-right mt-2">1. Swarga. 10. Nanma. 1. Thrithva.</span></li>
          </ol>
        </div>

        <div class="bg-purple-900/30 border border-purple-500/30 p-5 rounded-xl mt-8 mb-6">
          <h3 class="text-xl font-bold text-center text-white mb-4">Japamala Samarppanam</h3>
          <p class="text-justify text-purple-100 italic leading-relaxed">
            Mukhyadoothanaya vishudha mikhayele, daivadoothanmaraya vishudha gabriyele, vishudha rappayele, mahathmavaya vishudha yauseppe, shleehanmaraya vishudha pathrose, mar paulose, mar yohannane, njangalude pithavaya mar thomma, njangal valiya papikalayirikkunnuvengilum njangal japicha ee prarthana ningalude keerthanangalodukoode onnayi cherthu parishudha daivamathavinte thruppadathingal kazhchavaykkuvan ningalodu njangal prarthikkunnu.
          </p>
        </div>


        <div class="bg-blue-900/20 border border-blue-500/30 p-5 rounded-xl mt-8 mb-6">
          <h3 class="text-xl font-bold text-center text-white mb-6">Mathavinte Luthiniya</h3>
          <div class="text-purple-100 text-sm md:text-base leading-loose max-w-xl mx-auto rounded-lg bg-black/20 p-6 border border-white/5 font-serif">
            <p>Karthave anugrahikkaname <span class="text-blue-300 font-semibold">(Karthave...)</span></p>
            <p>Mishihaye anugrahikkaname <span class="text-blue-300 font-semibold">(Mishihaye...)</span></p>
            <p>Karthave anugrahikkaname <span class="text-blue-300 font-semibold">(Karthave...)</span></p>
            <p>Mishihaye njangalude prarthana kelkkaname <span class="text-blue-300 font-semibold">(Mishihaye...)</span></p>
            <p>Mishihaye njangalude prarthana kaikkollaname <span class="text-blue-300 font-semibold">(Mishihaye...)</span></p>

            <div class="my-4 border-t border-white/10"></div>

            <p>Swargasthanaya pithavaya daivame <span class="text-blue-300 font-semibold">(Njangale anugrahikkaname)</span></p>
            <p>Bhulokarakshakanaya puthranaya daivame <span class="text-blue-300 font-semibold">(Njangale anugrahikkaname)</span></p>
            <p>Parishudhathmavaya daivame <span class="text-blue-300 font-semibold">(Njangale anugrahikkaname)</span></p>
            <p>Ekadaivamaya parishudha thrithvame <span class="text-blue-300 font-semibold">(Njangale anugrahikkaname)</span></p>

            <div class="my-4 border-t border-white/10"></div>

            <p class="text-center text-blue-300 font-bold mb-4">"Njangalkkuvendi apekshikkaname"</p>
            
            <p>Parishudha mariyame...</p>
            <p>Daivathinte parishudha janani...</p>
            <p>Kanyakalkku makudamaya nirmmala kanyake...</p>
            <p>Mishihayude mathave...</p>
            <p>Daivavaraprasadathinte mathave...</p>
            <p>Prathyashayude mathave...</p>
            <p>Ettavum nirmmalayaya mathave...</p>
            <p>Athyantha virakthayaya mathave...</p>
            <p>Kalankamatta kanyakayaya mathave...</p>
            <p>Kanyathvathinu bhangam varatha mathave...</p>
            <p>Snehathinu ettam yogyayaya mathave...</p>
            <p>Albhutathinu vishayamaya mathave...</p>
            <p>Sadupadeshathinte mathave...</p>
            <p>Srushtavinte mathave...</p>
            <p>Thirusabhayude mathave...</p>
            <p>Karunayude mathave...</p>
            <p>Rakshakante mathave...</p>
            <p>Ettam vivekamathiyaya kanyake...</p>
            <p>Vanakkathinu ettam yogyayaya kanyake...</p>
            <p>Sthuthikku yogyayaya kanyake...</p>
            <p>Mahavallabhayaya kanyake...</p>
            <p>Kanivulla kanyake...</p>
            <p>Ettavum vishwasthayaya kanyake...</p>
            <p>Neethiyude darppaname...</p>
            <p>Divyajnjanathinte simhasaname...</p>
            <p>Njangalude santhoshathinte karaname...</p>
            <p>Aathmajnjanapooritha pathrame...</p>
            <p>Bahumanathinte pathrame...</p>
            <p>Athbhuthakaramaya bhakthiyude pathrame...</p>
            <p>Divyarahasyam niranjirikkunna rosapushpame...</p>
            <p>Davidinte kottaye...</p>
            <p>Nirmmaladantham kondulla kottaye...</p>
            <p>Swarnalayame...</p>
            <p>Vagdanathinte pedakame...</p>
            <p>Swargathinte vathile...</p>
            <p>Ushakala nakshathrame...</p>
            <p>Rogikalude arokkyame...</p>
            <p>Papikalude sankethame...</p>
            <p>Kudiyettakkarude aswasame...</p>
            <p>Peeditharude aswasame...</p>
            <p>Kristhyanikalude sahayame...</p>
            <p>Malakhamarude raajni...</p>
            <p>Poorvapithakkanmarude raajni...</p>
            <p>Deerghadarshikalude raajni...</p>
            <p>Shleehanmarude raajni...</p>
            <p>Vedasakshikalude raajni...</p>
            <p>Vandakanmarude raajni...</p>
            <p>Kudumbangalude raajni...</p>
            <p>Kanyakakalude raajni...</p>
            <p>Sakalavishudharudeyum raajni...</p>
            <p>Amalolbhavayaya raajni...</p>
            <p>Swargaropithayaya raajni...</p>
            <p>Parishudhajapamalayude raajni...</p>
            <p>Karmmalasabhayude alankaramaya raajni...</p>
            <p>Samadhanathinte raajni...</p>

            <div class="my-4 border-t border-white/10"></div>

            <p class="mt-4">Lokathinte papangal neekkunna divyakunjade <br><span class="text-blue-300 font-semibold">(Karthave njangalude papangal kshamikkaname)</span></p>
            <p class="mt-4">Lokathinte papangal neekkunna divyakunjade <br><span class="text-blue-300 font-semibold">(Karthave njangalude prarthana kelkkaname)</span></p>
            <p class="mt-4">Lokathinte papangal neekkunna divyakunjade <br><span class="text-blue-300 font-semibold">(Karthave njangale anugrahikkaname)</span></p>
