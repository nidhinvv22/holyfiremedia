---
import MainLayout from '../../layouts/MainLayout.astro';
import PlayerModal from '../../components/PlayerModal.astro';
import { songs } from '../../data/songs';
---

<MainLayout title="All Songs | HolyfireMedia" description="Browse all Malayalam Christian songs.">
  <script is:inline define:vars={{ playlist: songs }}>window.songsPlaylist = playlist;</script>
  <div class="container mx-auto px-4 py-16">
    <div class="mb-12">
      <h1 class="text-4xl md:text-5xl font-extrabold text-white mb-4">All Songs</h1>
      <p class="text-xl text-purple-200">
        Discover and listen to our vast collection of devotional music.
      </p>
    </div>

    <!-- Search/Filter Bar (Visual Placeholder) -->
    <div class="bg-white/10 backdrop-blur-md border border-white/20 p-4 rounded-xl mb-8 flex flex-col sm:flex-row gap-4">
      <div class="relative flex-1">
        <svg xmlns="http://www.w3.org/2000/svg" class="absolute left-3 top-1/2 -translate-y-1/2 h-5 w-5 text-purple-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
        <input type="text" placeholder="Search songs..." class="w-full bg-black/20 border border-white/10 rounded-lg py-3 pl-10 pr-4 text-white placeholder-purple-300 focus:outline-none focus:border-pink-500 transition-colors" />
      </div>
      <button class="px-6 py-3 bg-pink-500 hover:bg-pink-400 text-white font-medium rounded-lg transition-colors">
        Search
      </button>
    </div>

    <!-- Songs List -->
    <div class="bg-indigo-900/30 backdrop-blur-md border border-white/10 rounded-2xl overflow-hidden shadow-2xl">
      <div class="grid grid-cols-12 gap-4 p-4 border-b border-white/10 text-sm font-semibold text-purple-200 uppercase tracking-wider hidden md:grid">
        <div class="col-span-1 text-center">#</div>
        <div class="col-span-5">Title</div>
        <div class="col-span-3">Artist</div>
        <div class="col-span-1 text-center"><svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mx-auto" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg></div>
        <div class="col-span-2 text-right">Actions</div>
      </div>

      <div class="divide-y divide-white/5">
        {songs.map((song, index) => (
          <div onclick={`window.openGlobalPlayer(window.songsPlaylist, ${index})`} class="grid grid-cols-1 md:grid-cols-12 gap-4 p-4 items-center hover:bg-white/5 border border-transparent hover:border-pink-500/20 transition-all duration-300 group cursor-pointer rounded-2xl">
            <div class="col-span-1 text-center font-bold text-purple-400 hidden md:block">{index + 1}</div>
            
            <div class="col-span-12 md:col-span-5 flex items-center gap-3">
              <div class="h-10 w-10 min-w-[40px] rounded bg-gradient-to-br from-pink-500 to-purple-600 flex items-center justify-center shadow-md">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-white" viewBox="0 0 20 20" fill="currentColor">
                  <path d="M18 3a1 1 0 00-1.196-.98l-10 2A1 1 0 006 5v9.114A4.369 4.369 0 005 14c-1.657 0-3 .895-3 2s1.343 2 3 2 3-.895 3-2V7.536l8-1.6V12.114A4.369 4.369 0 0015 12c-1.657 0-3 .895-3 2s1.343 2 3 2 3-.895 3-2V3z" />
                </svg>
              </div>
              <div class="truncate">
                <h3 class="text-white font-bold group-hover:text-pink-300 transition-colors truncate">{song.title}</h3>
                <p class="text-purple-300 text-sm md:hidden">{song.artist}</p>
              </div>
            </div>
            
            <div class="col-span-3 text-purple-200 hidden md:block truncate"><a href="/artists" class="hover:text-pink-300 transition-colors">{song.artist}</a></div>
            
            <div class="col-span-1 text-purple-300 text-center hidden md:block">{song.duration}</div>
            
            <div class="col-span-12 md:col-span-2 flex gap-2 justify-end">
              {song.hasLyrics && (
                <a href={`/lyrics/${song.slug}`} onclick="event.stopPropagation()" class="px-3 py-1.5 bg-white/10 hover:bg-white/20 text-white text-sm font-medium rounded transition-colors">
                  Lyrics
                </a>
              )}
              {song.hasKaraoke && (
                <a href={`/karaoke/${song.slug}`} onclick="event.stopPropagation()" class="px-3 py-1.5 bg-pink-600 hover:bg-pink-500 text-white text-sm font-medium rounded shadow-md transition-transform hover:scale-105">
                  Karaoke
                </a>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
  <PlayerModal />
</MainLayout>
