---
import MainLayout from '../../layouts/MainLayout.astro';

// Placeholder Data
const artists = [
  { id: 1, name: "Artist One", bio: "Lorem ipsum dolor sit amet, consectetur adipiscing elit.", image: "https://placehold.co/400x400/3b0764/ffffff?text=Artist+1", slug: "artist-1", songCount: 12 },
  { id: 2, name: "Artist Two", bio: "Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua.", image: "https://placehold.co/400x400/3b0764/ffffff?text=Artist+2", slug: "artist-2", songCount: 8 },
  { id: 3, name: "Artist Three", bio: "Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris.", image: "https://placehold.co/400x400/3b0764/ffffff?text=Artist+3", slug: "artist-3", songCount: 15 },
  { id: 4, name: "Artist Four", bio: "Duis aute irure dolor in reprehenderit in voluptate velit esse.", image: "https://placehold.co/400x400/3b0764/ffffff?text=Artist+4", slug: "artist-4", songCount: 5 },
  { id: 5, name: "Artist Five", bio: "Excepteur sint occaecat cupidatat non proident, sunt in culpa qui.", image: "https://placehold.co/400x400/3b0764/ffffff?text=Artist+5", slug: "artist-5", songCount: 20 },
  { id: 6, name: "Artist Six", bio: "Officia deserunt mollit anim id est laborum.", image: "https://placehold.co/400x400/3b0764/ffffff?text=Artist+6", slug: "artist-6", songCount: 3 },
];
---

<MainLayout title="Artists | HolyfireMedia" description="Discover talented Christian artists and their complete discography.">
  <div class="container mx-auto px-4 py-16">
    <div class="mb-12 text-center max-w-2xl mx-auto">
      <h1 class="text-4xl md:text-5xl font-extrabold text-white mb-6">Our Artists</h1>
      <p class="text-xl text-purple-200">
        Browse through our collection of gifted artists dedicating their voices to worship and praise.
      </p>
    </div>

    <div class="grid sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-8">
      {artists.map((artist) => (
        <a href={`/artists/${artist.slug}`} class="block group">
          <div class="bg-white/5 backdrop-blur-md border border-white/10 p-5 rounded-2xl shadow-lg hover:shadow-pink-500/20 hover:bg-white/10 transition-all duration-300 transform group-hover:-translate-y-2">
            <div class="relative mb-6 overflow-hidden rounded-xl">
              <img src={artist.image} alt={artist.name} class="w-full aspect-square object-cover transition-transform duration-500 group-hover:scale-110" />
              <div class="absolute inset-0 bg-gradient-to-t from-purple-900/80 to-transparent flex items-end p-4">
                <span class="text-xs font-bold bg-pink-500 text-white px-3 py-1 rounded-full shadow-md">
                  {artist.songCount} Songs
                </span>
              </div>
            </div>
            <h2 class="text-2xl font-bold text-white mb-2 group-hover:text-pink-300 transition-colors">{artist.name}</h2>
            <p class="text-purple-200 line-clamp-2 text-sm">{artist.bio}</p>
          </div>
        </a>
      ))}
    </div>
  </div>
</MainLayout>
