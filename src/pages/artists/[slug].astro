---
import MainLayout from '../../layouts/MainLayout.astro';

export function getStaticPaths() {
  const artists = [
    { id: 1, name: "Artist One", slug: "artist-1" },
    { id: 2, name: "Artist Two", slug: "artist-2" },
    { id: 3, name: "Artist Three", slug: "artist-3" },
    { id: 4, name: "Artist Four", slug: "artist-4" },
    { id: 5, name: "Artist Five", slug: "artist-5" },
    { id: 6, name: "Artist Six", slug: "artist-6" },
  ];
  
  return artists.map((artist) => {
    return {
      params: { slug: artist.slug },
      props: { artist }
    };
  });
}

const { artist } = Astro.props;

// Placeholder songs for this artist
const artistSongs = [
  { id: 1, title: `${artist.name} - Song One`, hasKaraoke: true },
  { id: 2, title: `${artist.name} - Song Two`, hasKaraoke: false },
  { id: 3, title: `${artist.name} - Song Three`, hasKaraoke: true },
  { id: 4, title: `${artist.name} - Song Four`, hasKaraoke: true },
];
---

<MainLayout title={`${artist.name} | HolyfireMedia`}>
  <div class="container mx-auto px-4 py-16">
    <!-- Artist Header -->
    <div class="bg-indigo-900/40 backdrop-blur-xl border border-white/10 rounded-3xl p-8 md:p-12 shadow-2xl mb-12 flex flex-col md:flex-row gap-8 items-center md:items-start text-center md:text-left relative overflow-hidden">
      <!-- Decorative Background elements -->
      <div class="absolute -top-24 -right-24 w-64 h-64 bg-pink-500/20 rounded-full blur-3xl mix-blend-screen pointer-events-none"></div>
      <div class="absolute -bottom-24 -left-24 w-64 h-64 bg-purple-500/20 rounded-full blur-3xl mix-blend-screen pointer-events-none"></div>
      
      <img src={`https://placehold.co/400x400/3b0764/ffffff?text=${artist.name.replace(' ', '+')}`} alt={artist.name} class="w-48 h-48 md:w-64 md:h-64 object-cover rounded-full border-4 border-white/20 shadow-xl z-10" />
      
      <div class="flex-1 z-10">
        <h1 class="text-4xl md:text-6xl font-extrabold text-white mb-4">{artist.name}</h1>
        <p class="text-lg text-purple-200 mb-6 leading-relaxed max-w-2xl">
          Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris nisi ut aliquip ex ea commodo consequat.
        </p>
        <div class="flex flex-wrap gap-4 justify-center md:justify-start">
          <button class="px-6 py-3 bg-pink-500 hover:bg-pink-400 text-white font-bold rounded-xl shadow-lg shadow-pink-500/30 transition-all flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM9.555 7.168A1 1 0 008 8v4a1 1 0 001.555.832l3-2a1 1 0 000-1.664l-3-2z" clip-rule="evenodd" />
            </svg>
            Play All Songs
          </button>
        </div>
      </div>
    </div>

    <!-- Artist's Songs List -->
    <h2 class="text-3xl font-bold text-white mb-6">Songs by {artist.name}</h2>
    <div class="grid gap-4">
      {artistSongs.map((song, index) => (
        <div class="flex flex-col sm:flex-row items-center justify-between p-5 bg-white/5 hover:bg-white/10 border border-white/5 rounded-2xl transition-all group">
          <div class="flex items-center gap-4 w-full sm:w-auto mb-4 sm:mb-0">
            <div class="text-xl font-bold text-purple-400 w-8 text-center">{index + 1}</div>
            <div class="h-12 w-12 rounded-lg bg-white/10 flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-pink-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3" />
              </svg>
            </div>
            <div>
              <h3 class="text-lg font-bold text-white group-hover:text-pink-300 transition-colors">{song.title}</h3>
              {song.hasKaraoke ? (
                <span class="text-xs bg-emerald-500/20 text-emerald-300 px-2 py-1 rounded">Karaoke Available</span>
              ) : (
                <span class="text-xs text-purple-300">Vocals Only</span>
              )}
            </div>
          </div>
          
          <div class="flex gap-3 w-full sm:w-auto">
            <a href="/lyrics" class="flex-1 sm:flex-none text-center px-4 py-2 bg-white/10 hover:bg-white/20 text-white font-medium rounded-lg transition-colors">
              Lyrics
            </a>
            {song.hasKaraoke && (
              <a href="/karaoke" class="flex-1 sm:flex-none text-center px-4 py-2 bg-gradient-to-r from-purple-500 to-indigo-600 hover:from-purple-400 hover:to-indigo-500 text-white font-medium rounded-lg shadow-md transition-transform hover:scale-105 active:scale-95 text-nowrap">
                Buy Karaoke
              </a>
            )}
          </div>
        </div>
      ))}
    </div>
  </div>
</MainLayout>
