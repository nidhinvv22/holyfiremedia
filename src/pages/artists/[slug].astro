---
import MainLayout from '../../layouts/MainLayout.astro';
import PlayerModal from '../../components/PlayerModal.astro';
import frJosephImg from '../../assets/fr_joseph_mukkatt.webp';
import { songs } from '../../data/songs';

export function getStaticPaths() {
  const artists = [
    { 
      id: 1, 
      name: "Fr. Joseph Mukkatt", 
      slug: "fr-joseph-mukkatt",
      seoTitle: "Fr. Joseph Mukkatt Songs, Homilies & Karaoke | HolyfireMedia",
      seoDescription: "Listen to Malayalam Christian songs and homilies by Fr. Joseph Mukkatt. Read lyrics and download karaoke tracks for personal use.",
      useFrImage: true,
      bio: "Fr. Joseph Mukkatt is a Malayalam Catholic priest known for his spiritual homilies, Christian devotional songs, and faith-centered teachings. His messages focus on deepening personal faith, understanding the Word of God, and living a Christ-centered life.\n\nThrough his music and preaching, he has inspired many believers across the Malayalam Christian community. His songs and reflections are widely appreciated for their spiritual depth, simplicity, and connection to everyday life.",
      extendedDescription: "Fr. Joseph Mukkatt shares Malayalam Christian songs, homilies, and spiritual reflections that help believers grow in faith. His content includes devotional music, gospel reflections, and teachings rooted in Catholic tradition.\n\nListeners can explore his songs, read lyrics, and access karaoke versions for personal use. His work is especially popular among those searching for Malayalam Christian devotional songs and Catholic homily Malayalam online.",
      aboutMinistry: "Fr. Joseph Mukkatt’s ministry focuses on spreading the Word of God through music and preaching. His homilies and songs help believers reflect, pray, and grow spiritually."
    },
    { id: 2, name: "Artist Two", slug: "artist-2" },
    { id: 3, name: "Artist Three", slug: "artist-3" },
    { id: 4, name: "Artist Four", slug: "artist-4" },
    { id: 5, name: "Artist Five", slug: "artist-5" },
    { id: 6, name: "Artist Six", slug: "artist-6" },
  ];
  
  return artists.map((artist) => {
    return {
      params: { slug: artist.slug },
      props: { artist }
    };
  });
}

const { artist } = Astro.props;

// Fetch artist songs dynamically
const artistSongs = songs.filter(s => s.artist === artist.name).map(s => ({
  ...s,
  videoId: "dQw4w9WgXcQ" // Fallback video ID
}));

const finalSongs = artistSongs.length > 0 ? artistSongs : [
      { id: 1, title: `${artist.name} - Placeholder Song 1`, hasKaraoke: true, videoId: "dQw4w9WgXcQ" },
      { id: 2, title: `${artist.name} - Placeholder Song 2`, hasKaraoke: false, videoId: "dQw4w9WgXcQ" }
];

const decoratedSongs = finalSongs.map((s, index) => ({ ...s, id: index + 1, artist: artist.name }));

const artistImage = artist.useFrImage 
  ? frJosephImg.src 
  : `https://placehold.co/400x400/3b0764/ffffff?text=${artist.name.replace(/ /g, '+')}`;

const pageTitle = artist.seoTitle || `${artist.name} | HolyfireMedia`;
const pageDescription = artist.seoDescription || `Listen to songs and explore the discography of ${artist.name}.`;
const bioParas = artist.bio ? artist.bio.split('\n\n') : ["Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris nisi ut aliquip ex ea commodo consequat."];
const extendedParas = artist.extendedDescription ? artist.extendedDescription.split('\n\n') : [];
---

<MainLayout title={pageTitle} description={pageDescription}>
  <!-- Pass JSON stringified array to client script -->
  <script is:inline define:vars={{ playlist: decoratedSongs }}>
    window.artistPlaylist = playlist;
  </script>

  <div class="container mx-auto px-4 py-16">
    <!-- Artist Header -->
    <div class="bg-indigo-900/40 backdrop-blur-xl border border-white/10 rounded-3xl p-8 md:p-12 shadow-2xl mb-12 flex flex-col md:flex-row gap-8 items-center md:items-start text-center md:text-left relative overflow-hidden">
      <!-- Decorative Background elements -->
      <div class="absolute -top-24 -right-24 w-64 h-64 bg-pink-500/20 rounded-full blur-3xl mix-blend-screen pointer-events-none"></div>
      <div class="absolute -bottom-24 -left-24 w-64 h-64 bg-purple-500/20 rounded-full blur-3xl mix-blend-screen pointer-events-none"></div>
      
      <div class="relative w-48 h-48 md:w-64 md:h-64 rounded-full border-4 border-white/20 shadow-xl overflow-hidden z-10 flex-shrink-0 bg-gradient-to-br from-indigo-900 to-purple-900 flex items-center justify-center">
        {artist.useFrImage ? (
          <img src={artistImage} alt={artist.name} class="w-full h-full object-cover transition-transform duration-500 hover:scale-110" />
        ) : (
          <span class="text-6xl font-bold text-white/50">{artist.name.split(' ').map(n => n[0]).join('')}</span>
        )}
      </div>
      
      <div class="flex-1 z-10 w-full">
        <h1 class="text-4xl md:text-6xl font-extrabold text-white mb-4">{artist.name}</h1>
        <div class="text-lg text-purple-200 mb-6 leading-relaxed max-w-2xl space-y-4">
          {bioParas.map((para) => <p>{para}</p>)}
        </div>
        <div class="flex flex-wrap gap-4 justify-center md:justify-start">
          <button onclick="window.openGlobalPlayer(window.artistPlaylist, 0)" class="px-6 py-3 bg-pink-500 hover:bg-pink-400 text-white font-bold rounded-xl shadow-lg shadow-pink-500/30 transition-all flex items-center gap-2 transform hover:-translate-y-1 active:scale-95">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM9.555 7.168A1 1 0 008 8v4a1 1 0 001.555.832l3-2a1 1 0 000-1.664l-3-2z" clip-rule="evenodd" />
            </svg>
            Play All Songs
          </button>
        </div>
      </div>
    </div>
    
    <!-- Featured Song Section -->
    <div class="mb-12 bg-gradient-to-r from-pink-900/30 to-purple-900/30 border border-pink-500/20 rounded-2xl p-6 md:p-8 backdrop-blur-sm shadow-xl flex flex-col md:flex-row items-center justify-between gap-6 hover:shadow-pink-500/10 transition-shadow">
      <div class="text-center md:text-left">
        <span class="text-pink-400 font-bold tracking-wider text-sm uppercase mb-2 block">Featured Song</span>
        <h2 class="text-2xl md:text-3xl font-bold text-white mb-2">Aradhyane Parishudhane | Ennullam Thirayunnori</h2>
        <p class="text-purple-200">Experience the spiritual depth of this beautiful devotional song by {artist.name}.</p>
      </div>
      <button onclick="window.openGlobalPlayer(window.artistPlaylist, 0)" class="px-8 py-4 bg-gradient-to-r from-pink-500 to-purple-600 hover:from-pink-400 hover:to-purple-500 text-white font-bold rounded-xl shadow-lg shadow-pink-500/30 transition-transform hover:-translate-y-1 active:scale-95 flex items-center gap-2 whitespace-nowrap">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM9.555 7.168A1 1 0 008 8v4a1 1 0 001.555.832l3-2a1 1 0 000-1.664l-3-2z" clip-rule="evenodd" />
        </svg>
        Play Now
      </button>
    </div>

    {/* SEO Oriented Content Sections */}
    <div class="grid md:grid-cols-2 gap-8 mb-12">
      {artist.extendedDescription && (
        <div class="bg-white/5 border border-white/10 rounded-2xl p-6 md:p-8 backdrop-blur-sm shadow-xl transition-all hover:bg-white/10">
          <h2 class="text-2xl font-bold text-white mb-4">Learn More About {artist.name}</h2>
          <div class="text-purple-200 leading-relaxed space-y-4">
            {extendedParas.map((para) => <p>{para}</p>)}
          </div>
        </div>
      )}
  
      {artist.aboutMinistry && (
        <div class="bg-white/5 border border-white/10 rounded-2xl p-6 md:p-8 backdrop-blur-sm shadow-xl transition-all hover:bg-white/10">
          <h2 class="text-2xl font-bold text-white mb-4">About His Ministry</h2>
          <div class="text-purple-200 leading-relaxed text-lg">
            <p>{artist.aboutMinistry}</p>
          </div>
        </div>
      )}
    </div>

    <!-- Artist's Songs List -->
    <h2 class="text-3xl font-bold text-white mb-6">Listen to Songs by {artist.name}</h2>
    <div class="grid gap-4">
      {decoratedSongs.map((song, index) => (
        <div onclick={`window.openGlobalPlayer(window.artistPlaylist, ${index})`} class="flex flex-col sm:flex-row items-center justify-between p-5 bg-white/5 hover:bg-white/10 border border-white/5 hover:border-pink-500/30 rounded-2xl transition-all duration-300 group shadow-lg hover:shadow-pink-500/10 cursor-pointer">
          <div class="flex items-center gap-4 w-full sm:w-auto mb-4 sm:mb-0">
            <div class="text-xl font-bold text-purple-400 w-8 text-center group-hover:text-pink-400 transition-colors">{index + 1}</div>
            
            {/* Play Button simulating Modal Open */}
            <button class="h-12 w-12 flex-shrink-0 rounded-lg bg-pink-500/20 flex items-center justify-center cursor-pointer hover:bg-pink-500 hover:text-white text-pink-300 transition-all transform group-hover:scale-110 active:scale-95 shadow-md" title="Play">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 ml-1" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM9.555 7.168A1 1 0 008 8v4a1 1 0 001.555.832l3-2a1 1 0 000-1.664l-3-2z" clip-rule="evenodd" />
              </svg>
            </button>
            
            <div>
              <h3 class="text-lg font-bold text-white group-hover:text-pink-300 transition-colors">{song.title}</h3>
              {song.hasKaraoke ? (
                <span class="text-xs font-semibold bg-emerald-500/20 text-emerald-300 px-2 py-1 rounded shadow-sm inline-flex items-center gap-1"><span class="text-[10px]">🎤</span> Karaoke Available</span>
              ) : (
                <span class="text-xs font-semibold text-purple-300 bg-purple-900/40 px-2 py-1 rounded shadow-sm">Vocals Only</span>
              )}
            </div>
          </div>
          
          <div class="flex gap-3 w-full sm:w-auto mt-4 sm:mt-0 justify-end flex-wrap">
            {song.hasLyrics !== false && (
              <a href={song.slug ? `/lyrics/${song.slug}` : "/lyrics"} onclick="event.stopPropagation()" class="flex-1 sm:flex-none flex items-center justify-center px-6 py-2 bg-white/10 hover:bg-white/20 text-white font-medium rounded-lg transition-all border border-white/10 shadow-sm hover:shadow-md hover:-translate-y-0.5 text-sm md:text-base">
                Lyrics
              </a>
            )}
            {song.hasKaraoke && (
              <div class="flex-1 sm:flex-none flex flex-col items-center">
                <a href={song.slug ? `/karaoke/${song.slug}` : "/karaoke"} onclick="event.stopPropagation()" class="w-full text-center px-4 md:px-6 py-2 bg-gradient-to-r from-purple-500 to-indigo-600 hover:from-purple-400 hover:to-indigo-500 text-white font-medium rounded-lg shadow-md transition-all hover:shadow-lg hover:-translate-y-0.5 active:scale-95 text-nowrap flex items-center gap-2 justify-center text-sm md:text-base">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
                    <path d="M3 1a1 1 0 000 2h1.22l.305 1.222a.997.997 0 00.01.042l1.358 5.43-.893.892C3.74 11.846 4.632 14 6.414 14H15a1 1 0 000-2H6.414l1-1H14a1 1 0 00.894-.553l3-6A1 1 0 0017 3H6.28l-.31-1.243A1 1 0 005 1H3zM16 16.5a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0zM6.5 18a1.5 1.5 0 100-3 1.5 1.5 0 000 3z" />
                  </svg>
                  Get Karaoke Version
                </a>
                <span class="text-[10px] text-purple-300 mt-1.5 opacity-80">Instant download after payment</span>
              </div>
            )}
          </div>
        </div>
      ))}
    </div>

    <!-- What is Karaoke Section -->
    <div class="mt-12 bg-indigo-900/40 border border-indigo-500/30 rounded-2xl p-6 md:p-8 backdrop-blur-sm shadow-xl">
      <h2 class="text-2xl font-bold text-white mb-6 flex items-center gap-3">
        <span class="text-2xl">🎤</span> What is Karaoke?
      </h2>
      <div class="grid sm:grid-cols-2 gap-6 text-purple-200">
        <div class="bg-white/5 border border-white/10 hover:border-pink-500/30 transition-colors rounded-xl p-6">
          <h3 class="font-bold text-pink-300 mb-2 text-lg">With Chorus</h3>
          <p class="text-sm md:text-base">Free version that includes backing vocals. Great for learning the lyrics and familiarizing yourself with the rhythm.</p>
        </div>
        <div class="bg-white/5 border border-white/10 hover:border-emerald-500/30 transition-colors rounded-xl p-6">
          <h3 class="font-bold text-emerald-300 mb-2 text-lg">Without Chorus</h3>
          <p class="text-sm md:text-base">Paid instrumental version perfect for singing practice, creating covers, and performing at devotional events.</p>
        </div>
      </div>
    </div>

    <!-- Final SEO Paragraph -->
    <div class="mt-16 text-center border-t border-white/10 pt-8 pb-4">
      <p class="text-purple-300 text-sm md:text-base max-w-4xl mx-auto leading-relaxed">
        {artist.name === "Fr. Joseph Mukkatt" ? "Fr Joseph Mukkatt Malayalam Christian songs, homilies, and devotional music are widely loved among believers. Explore lyrics, listen online, and download karaoke tracks for personal use." : `Discover top Christian tracks from ${artist.name}. Enjoy lyrics and get karaoke versions instantly.`}
      </p>
    </div>
  </div>

  <PlayerModal />
</MainLayout>
