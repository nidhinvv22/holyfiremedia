---
import MainLayout from '../../layouts/MainLayout.astro';
import { songs } from '../../data/songs';
---

<MainLayout title="Premium Karaoke | HolyfireMedia" description="Download studio quality Christian karaoke tracks.">
  <div class="container mx-auto px-4 py-16">
    <div class="text-center max-w-3xl mx-auto mb-16">
      <h1 class="text-4xl md:text-6xl font-extrabold text-transparent bg-clip-text bg-gradient-to-r from-pink-300 to-purple-300 drop-shadow-lg mb-6">
        Premium Karaoke Tracks
      </h1>
      <p class="text-xl text-purple-200 leading-relaxed">
        Professional studio-quality karaoke tracks designed to match the original song feel. All tracks are original productions or used with proper permissions.
      </p>
    </div>

    <!-- Available Tracks List -->
    <div class="max-w-4xl mx-auto animate-fade-in-up">
      <h2 class="text-3xl font-bold text-white mb-8 border-b border-white/10 pb-4">Available Tracks</h2>
      
      <div class="space-y-4">
        {songs.map((track) => (
          <a href={`/karaoke/${track.slug}`} class="block bg-indigo-900/40 backdrop-blur-md border border-white/10 p-6 rounded-2xl flex flex-col md:flex-row items-center justify-between gap-6 hover:bg-white/10 transition-colors group">
            <div class="flex items-center gap-4 w-full md:w-auto">
              <div class="h-14 w-14 rounded-full bg-gradient-to-r from-pink-500 to-purple-600 flex items-center justify-center shadow-lg group-hover:animate-pulse">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z" /></svg>
              </div>
              <div>
                <h3 class="text-xl font-bold text-white group-hover:text-pink-300 transition-colors">{track.title}</h3>
                <p class="text-purple-300">Original: {track.artist}</p>
              </div>
            </div>
            
            <div class="flex gap-3 w-full md:w-auto">
              <span class="flex-1 md:flex-none px-6 py-3 bg-white/10 group-hover:bg-white/20 border border-white/20 text-white font-semibold rounded-xl transition-colors text-center inline-flex justify-center items-center">
                View Versions
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </div>
</MainLayout>
