---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Privacy Policy">
  <div class="min-h-screen bg-gradient-to-br from-purple-900 via-indigo-900 to-blue-900 text-white">
    <main class="container mx-auto px-4 py-20 max-w-3xl">
      <h1 class="text-4xl md:text-5xl font-extrabold mb-6">Privacy Policy</h1>
      <div class="bg-white/10 backdrop-blur-lg border border-white/20 rounded-2xl p-8 space-y-5 text-purple-100">
        <section class="space-y-2">
          <h2 class="text-2xl font-semibold text-white">Information Collected</h2>
          <p>Name and email address may be collected during payment processing.</p>
        </section>
        <section class="space-y-2">
          <h2 class="text-2xl font-semibold text-white">Usage</h2>
          <p>Data is used for order processing and communication regarding purchases.</p>
        </section>
        <section class="space-y-2">
          <h2 class="text-2xl font-semibold text-white">No Selling</h2>
          <p>We do not sell your data to third parties.</p>
        </section>
        <section class="space-y-2">
          <h2 class="text-2xl font-semibold text-white">Secure Handling</h2>
          <p>All personal information is handled securely in accordance with best practices.</p>
        </section>
      </div>
    </main>

    <footer class="border-t border-white/10 py-6">
      <div class="container mx-auto px-4 text-center text-purple-200">
        <p>© 2026 HolyfireMedia | Contact: jmmusicdistribution@gmail.com</p>
      </div>
    </footer>
  </div>
</Layout>
