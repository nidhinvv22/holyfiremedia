---
import MainLayout from '../../layouts/MainLayout.astro';

const lyricsParams = [
  { id: 1, title: "Daivame Kaithozham", artist: "Traditional", lyricsSnippet: "Daivame kaithozham keralam mannil...\nKarunyam nirayum kanivodu kanmane..." },
  { id: 2, title: "Kaval Malakhamare", artist: "Traditional", lyricsSnippet: "Kaval malakhamare kanivolum...\nSnehathal pothiyunne enne..." },
  { id: 3, title: "Athmavile", artist: "Artist Three", lyricsSnippet: "Athmavile anuragame...\nEashowye nin anugrahame..." },
  { id: 4, title: "Snahithane", artist: "Artist One", lyricsSnippet: "Snehithane snehamam eashowye...\nNin hridhayam thedunnu njan..." }
];
---

<MainLayout title="Song Lyrics | HolyfireMedia" description="Read and devotionally sing Malayalam Christian song lyrics.">
  <div class="container mx-auto px-4 py-16">
    <div class="mb-12 max-w-2xl">
      <h1 class="text-4xl md:text-5xl font-extrabold text-white mb-4">Song Lyrics</h1>
      <p class="text-xl text-purple-200">
        Sing along with our curated collection of Christian song lyrics in Manglish and Malayalam.
      </p>
    </div>

    <div class="grid lg:grid-cols-2 gap-8">
      {lyricsParams.map((item) => (
        <div class="bg-indigo-900/40 backdrop-blur-xl border border-white/10 rounded-3xl p-6 md:p-8 shadow-2xl relative overflow-hidden group">
          <!-- Decorative Blur Background -->
          <div class="absolute -top-10 -right-10 w-32 h-32 bg-pink-500/20 rounded-full blur-3xl mix-blend-screen opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
          
          <div class="flex justify-between items-start mb-6 border-b border-white/10 pb-6 relative z-10">
            <div>
              <h2 class="text-2xl font-bold text-white mb-1 group-hover:text-pink-300 transition-colors">{item.title}</h2>
              <p class="text-purple-300">by {item.artist}</p>
            </div>
            <div class="h-10 w-10 flex-shrink-0 bg-white/10 rounded-full flex items-center justify-center border border-white/20">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-pink-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z" />
              </svg>
            </div>
          </div>
          
          <div class="relative z-10">
            <pre class="font-sans text-purple-100/90 whitespace-pre-line font-medium text-lg leading-relaxed italic border-l-4 border-pink-500/50 pl-4 mb-6">
              "{item.lyricsSnippet}"
            </pre>
            
            <button class="w-full py-3 bg-white/5 hover:bg-white/10 border border-white/20 text-white font-medium rounded-xl transition-all hover:border-pink-500/50 group-hover:shadow-[0_0_15px_rgba(236,72,153,0.3)]">
              Read Full Lyrics
            </button>
          </div>
        </div>
      ))}
    </div>
  </div>
</MainLayout>
