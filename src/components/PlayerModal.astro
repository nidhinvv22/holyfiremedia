---
// PlayerModal.astro
---
<div id="global-player-modal" class="fixed inset-0 z-[100] hidden items-center justify-center">
  <!-- Dark overlay -->
  <div id="modal-overlay" class="absolute inset-0 bg-black/80 backdrop-blur-sm transition-opacity opacity-0 duration-300"></div>
  
  <!-- Modal Content -->
  <div id="modal-content" class="relative bg-gradient-to-br from-indigo-950 to-purple-900 border border-white/20 w-full max-w-2xl mx-4 rounded-3xl shadow-2xl overflow-hidden transition-all transform scale-95 opacity-0 duration-300 z-10">
    
    <!-- Header -->
    <div class="px-6 py-4 flex justify-between items-center border-b border-white/10">
      <div>
        <h3 id="modal-song-title" class="text-xl font-bold text-white">Song Title</h3>
        <p id="modal-artist-name" class="text-purple-300 text-sm">Artist Name</p>
      </div>
      <button id="close-modal-btn" class="p-2 text-white/70 hover:text-white bg-white/5 hover:bg-white/20 rounded-full transition-colors focus:outline-none">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
    
    <!-- Player (Iframe) -->
    <div class="p-6 md:p-8 bg-black/50 flex flex-col gap-6">
      <div class="w-full aspect-video rounded-xl overflow-hidden border border-white/5 shadow-inner bg-black">
        <iframe 
          id="modal-youtube-iframe"
          width="100%" 
          height="100%" 
          src="" 
          title="YouTube video player" 
          frameborder="0" 
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" 
          allowfullscreen
          class="w-full h-full"
        ></iframe>
      </div>
      
      <!-- Basic Controls -->
      <div class="flex justify-between items-center px-4">
          <button id="modal-prev-btn" class="px-4 py-2 bg-white/10 hover:bg-white/20 text-white rounded-lg flex items-center gap-2 transition-colors disabled:opacity-50 disabled:cursor-not-allowed">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
              <path d="M8.445 14.832A1 1 0 0010 14v-2.798l5.445 3.63A1 1 0 0017 14V6a1 1 0 00-1.555-.832L10 8.798V6a1 1 0 00-1.555-.832l-6 4a1 1 0 000 1.664l6 4z" />
            </svg>
            <span class="hidden sm:inline">Prev</span>
          </button>
          
          <button id="modal-next-btn" class="px-4 py-2 bg-white/10 hover:bg-white/20 text-white rounded-lg flex items-center gap-2 transition-colors disabled:opacity-50 disabled:cursor-not-allowed">
            <span class="hidden sm:inline">Next</span>
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
               <path d="M11 4a1 1 0 011.555-.832l6 4a1 1 0 010 1.664l-6 4A1 1 0 0111 12V4z" />
               <path d="M4 4a1 1 0 011.555-.832l6 4a1 1 0 010 1.664l-6 4A1 1 0 014 12V4z" />
            </svg>
          </button>
      </div>
    </div>
    
  </div>
</div>

<script>
  let currentPlaylist = [];
  let currentIndex = -1;

  const modal = document.getElementById('global-player-modal');
  const overlay = document.getElementById('modal-overlay');
  const content = document.getElementById('modal-content');
  const closeBtn = document.getElementById('close-modal-btn');
  const iframe = document.getElementById('modal-youtube-iframe');
  
  const titleEl = document.getElementById('modal-song-title');
  const artistEl = document.getElementById('modal-artist-name');
  const nextBtn = document.getElementById('modal-next-btn');
  const prevBtn = document.getElementById('modal-prev-btn');

  function closeModal() {
    overlay?.classList.remove('opacity-100');
    overlay?.classList.add('opacity-0');
    content?.classList.remove('scale-100', 'opacity-100');
    content?.classList.add('scale-95', 'opacity-0');
    
    setTimeout(() => {
      modal?.classList.add('hidden');
      modal?.classList.remove('flex');
      if (iframe) iframe.src = ''; // stop playing
    }, 300);
  }

  function updateControls() {
    if (prevBtn) prevBtn.disabled = currentIndex <= 0;
    if (nextBtn) nextBtn.disabled = currentIndex >= currentPlaylist.length - 1;
  }

  function playSong(index) {
    if (index >= 0 && index < currentPlaylist.length) {
      currentIndex = index;
      const song = currentPlaylist[index];
      
      if (titleEl) titleEl.innerText = song.title;
      if (artistEl) artistEl.innerText = song.artist || 'Unknown Artist';
      if (iframe) iframe.src = `https://www.youtube.com/embed/${song.videoId}?autoplay=1`;
      
      updateControls();
    }
  }

  function openModal() {
    modal?.classList.remove('hidden');
    modal?.classList.add('flex');
    
    // trigger reflow
    void modal?.offsetWidth;
    
    overlay?.classList.remove('opacity-0');
    overlay?.classList.add('opacity-100');
    content?.classList.remove('scale-95', 'opacity-0');
    content?.classList.add('scale-100', 'opacity-100');
  }

  // Define global player handler
  window.openGlobalPlayer = (playlist, startIndex) => {
    currentPlaylist = playlist;
    playSong(startIndex);
    openModal();
  };

  closeBtn?.addEventListener('click', closeModal);
  overlay?.addEventListener('click', closeModal);
  
  nextBtn?.addEventListener('click', () => {
    if (currentIndex < currentPlaylist.length - 1) playSong(currentIndex + 1);
  });
  
  prevBtn?.addEventListener('click', () => {
    if (currentIndex > 0) playSong(currentIndex - 1);
  });

</script>
